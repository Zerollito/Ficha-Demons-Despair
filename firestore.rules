rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/connection {
      allow read: if true;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.get('email_verified', false) == true; }
    function isOwner(data) { return isSignedIn() && data.get('userId', '') == request.auth.uid; }
    function isMember() { return isSignedIn(); } // Simplified for reliability

    // Validation helper for Material
    function isValidMaterial(data) {
      return data.keys().hasAll(['id', 'nome', 'masterId']) &&
             data.id is string && data.id.size() <= 128 &&
             data.nome is string && data.nome.size() <= 200 &&
             data.masterId == request.auth.uid;
    }

    // Validation helper for BestiaryMonster
    function isValidMonster(data) {
      return data.keys().hasAll(['id', 'name', 'masterId']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.masterId == request.auth.uid;
    }

    // Character validation
    function isValidCharacter(data) {
      return data.get('id', '') != '' &&
             data.get('nome', '') != '' &&
             (data.get('userId', '') != '' || data.get('userEmail', '') != '');
    }

    // Helper for character ownership
    function isCharOwner(charId) {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/characters/$(charId)) && (
          get(/databases/$(database)/documents/characters/$(charId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/characters/$(charId)).data.userEmail == request.auth.token.email
        )) ||
        (request.resource != null && (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.userEmail == request.auth.token.email
        ))
      );
    }

    // Validation helper for Campaign
    function isValidCampaign(data) {
      let requiredFields = ['name', 'masterId', 'inviteCode', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.name is string && data.name.size() <= 100 &&
             data.masterId is string && data.masterId.size() <= 128 &&
             data.inviteCode is string && data.inviteCode.size() == 6 &&
             data.createdAt == request.time;
    }

    match /campaigns/{campaignId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.get('masterId', '') == request.auth.uid ||
        resource.data.get('masterEmail', '') == request.auth.token.get('email', '')
      );

      // VTT Tokens
      match /tokens/{tokenId} {
        allow read, write: if isSignedIn();
      }

      // VTT Config
      match /config/{configId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      // VTT Combat Logs
      match /vtt_logs/{logId} {
        allow read, write: if isSignedIn();
      }
    }

    match /bestiary/{monsterId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.get('masterId', '') == request.auth.uid ||
        resource.data.get('masterEmail', '') == request.auth.token.get('email', '')
      );
    }

    match /materials/{materialId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.get('masterId', '') == request.auth.uid ||
        resource.data.get('masterEmail', '') == request.auth.token.get('email', '')
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /characters/{characterId} {
      allow read: if isSignedIn() && (
        resource.data.get('userId', '') == request.auth.uid ||
        resource.data.get('userEmail', '') == request.auth.token.get('email', '') ||
        resource.data.get('campaignId', '') != ''
      );
      
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        // Owner can do everything
        resource.data.get('userId', '') == request.auth.uid ||
        resource.data.get('userEmail', '') == request.auth.token.get('email', '') ||
        // Master can do everything
        (resource.data.get('campaignId', '') != '' && 
         exists(/databases/$(database)/documents/campaigns/$(resource.data.campaignId)) &&
         (get(/databases/$(database)/documents/campaigns/$(resource.data.campaignId)).data.get('masterId', '') == request.auth.uid ||
          get(/databases/$(database)/documents/campaigns/$(resource.data.campaignId)).data.get('masterEmail', '') == request.auth.token.get('email', ''))) ||
        // Other players in same campaign can update combat stats and inventory (for looting)
        (resource.data.get('campaignId', '') != '' && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['vidaAtual', 'efeitosNegativos', 'isDefending', 'defenseType', 'defenseWeaponId', 'defenseRounds', 'updatedAt', 'armas', 'catalisadores', 'armaduras', 'acessorios', 'compartimentos', 'dinheiro']))
      );

      allow delete: if isSignedIn() && (
        resource.data.get('userId', '') == request.auth.uid ||
        resource.data.get('userEmail', '') == request.auth.token.get('email', '')
      );
    }
  }
}

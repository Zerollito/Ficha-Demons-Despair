rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/connection {
      allow read: if true;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(data) { return isSignedIn() && data.get('userId', '') == request.auth.uid; }
    function isMember() { return isSignedIn(); } // Simplified for reliability

    // Validation helper for Material
    function isValidMaterial(data) {
      return data.keys().hasAll(['id', 'nome', 'masterId']) &&
             data.id is string && data.id.size() <= 128 &&
             data.nome is string && data.nome.size() <= 200 &&
             data.masterId == request.auth.uid;
    }

    // Validation helper for BestiaryMonster
    function isValidMonster(data) {
      return data.keys().hasAll(['id', 'name', 'masterId']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.masterId == request.auth.uid;
    }

    // Character validation
    function isValidCharacter(data) {
      return data.get('id', '') != '' &&
             data.get('nome', '') != '' &&
             (data.get('user_id', '') != '' || data.get('user_email', '') != '');
    }

    // Helper for character ownership
    function isCharOwner(charId) {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/characters/$(charId)) && (
          get(/databases/$(database)/documents/characters/$(charId)).data.user_id == request.auth.uid ||
          get(/databases/$(database)/documents/characters/$(charId)).data.user_email == request.auth.token.email
        )) ||
        (request.resource != null && (
          request.resource.data.user_id == request.auth.uid ||
          request.resource.data.user_email == request.auth.token.email
        ))
      );
    }

    // Validation helper for Campaign
    function isValidCampaign(data) {
      let requiredFields = ['name', 'masterId', 'inviteCode', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.name is string && data.name.size() <= 100 &&
             data.masterId is string && data.masterId.size() <= 128 &&
             data.inviteCode is string && data.inviteCode.size() == 6 &&
             data.createdAt == request.time;
    }

    match /campaigns/{campaignId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.get('masterId', '') == request.auth.uid ||
        resource.data.get('master_id', '') == request.auth.uid ||
        resource.data.get('masterEmail', '') == request.auth.token.email ||
        resource.data.get('master_email', '') == request.auth.token.email ||
        (resource.data.get('data', null) != null && (
          resource.data.data.get('masterId', '') == request.auth.uid ||
          resource.data.data.get('masterEmail', '') == request.auth.token.email
        ))
      );

      // VTT Tokens
      match /tokens/{tokenId} {
        allow read, write: if true;
      }

      // VTT Config
      match /config/{configId} {
        allow read, write: if true;
      }

      // VTT Combat Logs
      match /vtt_logs/{logId} {
        allow read, write: if true;
      }
    }

    match /bestiary/{monsterId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.get('masterId', '') == request.auth.uid ||
        resource.data.get('master_id', '') == request.auth.uid ||
        resource.data.get('masterEmail', '') == request.auth.token.email ||
        resource.data.get('master_email', '') == request.auth.token.email ||
        (resource.data.get('data', null) != null && (
          resource.data.data.get('masterId', '') == request.auth.uid ||
          resource.data.data.get('masterEmail', '') == request.auth.token.email
        ))
      );
    }

    match /materials/{materialId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.get('masterId', '') == request.auth.uid ||
        resource.data.get('master_id', '') == request.auth.uid ||
        resource.data.get('masterEmail', '') == request.auth.token.email ||
        resource.data.get('master_email', '') == request.auth.token.email ||
        (resource.data.get('data', null) != null && (
          resource.data.data.get('masterId', '') == request.auth.uid ||
          resource.data.data.get('masterEmail', '') == request.auth.token.email
        ))
      );
    }

    match /custom_items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.get('masterId', '') == request.auth.uid ||
        resource.data.get('master_id', '') == request.auth.uid ||
        resource.data.get('masterEmail', '') == request.auth.token.email ||
        resource.data.get('master_email', '') == request.auth.token.email ||
        (resource.data.get('data', null) != null && (
          resource.data.data.get('masterId', '') == request.auth.uid ||
          resource.data.data.get('masterEmail', '') == request.auth.token.email
        ))
      );
    }

    match /custom_spells/{spellId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.get('masterId', '') == request.auth.uid ||
        resource.data.get('master_id', '') == request.auth.uid ||
        resource.data.get('masterEmail', '') == request.auth.token.email ||
        resource.data.get('master_email', '') == request.auth.token.email ||
        (resource.data.get('data', null) != null && (
          resource.data.data.get('masterId', '') == request.auth.uid ||
          resource.data.data.get('master_email', '') == request.auth.token.email ||
          resource.data.data.get('masterEmail', '') == request.auth.token.email
        ))
      );
    }

    match /tokens/{tokenId} {
      allow read, write: if true;
    }

    match /campaign_configs/{configId} {
      allow read, write: if true;
    }

    match /vtt_logs/{logId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /characters/{characterId} {
      allow read, write: if isSignedIn();
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/connection {
      allow read: if true;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(data) { return isSignedIn() && data.userId == request.auth.uid; }

    // Validation helper for Character
    function isValidCharacter(data, isUpdate) {
      let baseValid = data.keys().hasAll(['id', 'nome', 'userId', 'updatedAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.nome is string && data.nome.size() <= 200 &&
             data.updatedAt == request.time &&
             (data.get('createdAt', request.time) == request.time || data.createdAt == existing().createdAt);
      
      return baseValid && (isUpdate ? data.userId == existing().userId : data.userId == request.auth.uid);
    }

    // Validation helper for Campaign
    function isValidCampaign(data) {
      return data.keys().hasAll(['name', 'masterId', 'inviteCode', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() <= 100 &&
             data.masterId == request.auth.uid &&
             data.inviteCode is string && data.inviteCode.size() == 6 &&
             data.createdAt == request.time;
    }

    match /campaigns/{campaignId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(campaignId) && isValidCampaign(incoming());
      allow update: if isVerified() && 
                       existing().masterId == request.auth.uid && 
                       isValidId(campaignId) &&
                       isValidCampaign(incoming()) &&
                       incoming().masterId == existing().masterId &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'inviteCode']);
      allow delete: if isVerified() && existing().masterId == request.auth.uid;

      // VTT Tokens
      match /tokens/{tokenId} {
        allow read: if isSignedIn();
        allow write: if isVerified(); // Simplification: any member can move tokens for now
      }

      // VTT Config
      match /config/{configId} {
        allow read: if isSignedIn();
        allow write: if isVerified() && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.masterId == request.auth.uid;
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isVerified() && request.auth.uid == userId;
    }

    match /characters/{characterId} {
      // Helper to check if user is master of the character's campaign
      function isMasterOfCampaign(data) {
        let campId = data.get('campaignId', '');
        return campId != '' && get(/databases/$(database)/documents/campaigns/$(campId)).data.masterId == request.auth.uid;
      }

      // Secure List Queries
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isMasterOfCampaign(resource.data));
      allow get: if isSignedIn() && (isOwner(existing()) || isMasterOfCampaign(existing()));
      
      allow create: if isVerified() && 
                       isValidId(characterId) && 
                       incoming().createdAt == request.time &&
                       isValidCharacter(incoming(), false);

      allow update: if isVerified() && 
                       (isOwner(existing()) || isMasterOfCampaign(existing())) &&
                       isValidId(characterId) &&
                       isValidCharacter(incoming(), true) &&
                       incoming().userId == existing().userId &&
                       incoming().createdAt == existing().createdAt &&
                       // Action-based pattern: allow updating various fields
                       incoming().diff(existing()).affectedKeys().hasOnly([
                         'nome', 'etnia', 'dinheiro', 'vidaAtual', 'manaAtual', 
                         'fome', 'sede', 'cansaco', 'defesa', 'clima', 
                         'stats', 'statsXP', 'bonusProficiencias', 'joias', 
                         'imagem', 'armas', 'catalisadores', 'habilidades', 
                         'magias', 'armaduras', 'acessorios', 'compartimentos', 
                         'conhecimentos', 'efeitosNegativos', 'anotacoes', 
                         'escalas', 'dadosCustomizados', 'imagens', 'updatedAt',
                         'campaignId' // Allow joining campaigns
                       ]);

      allow delete: if isVerified() && (isOwner(existing()) || isMasterOfCampaign(existing()));
    }
  }
}

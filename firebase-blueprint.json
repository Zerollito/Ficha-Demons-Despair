{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User specific data and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "Campaign": {
      "title": "Campaign",
      "description": "An RPG campaign session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "masterId": { "type": "string" },
        "inviteCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "masterId", "inviteCode"]
    },
    "Character": {
      "title": "Character",
      "description": "A character in the RPG system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "userId": { "type": "string" },
        "campaignId": { "type": "string" },
        "etnia": { "type": "string" },
        "dinheiro": {
          "type": "object",
          "properties": {
            "C": { "type": "number" },
            "B": { "type": "number" },
            "P": { "type": "number" },
            "O": { "type": "number" }
          }
        },
        "vidaAtual": { "type": "number" },
        "manaAtual": { "type": "number" },
        "fome": { "type": "number" },
        "sede": { "type": "number" },
        "cansaco": { "type": "number" },
        "defesa": { "type": "object" },
        "clima": { "type": "number" },
        "stats": { "type": "object" },
        "statsXP": { "type": "object" },
        "bonusProficiencias": { "type": "object" },
        "joias": { "type": "array" },
        "imagem": { "type": "string" },
        "armas": { "type": "array" },
        "catalisadores": { "type": "array" },
        "habilidades": { "type": "array" },
        "magias": { "type": "array" },
        "armaduras": { "type": "array" },
        "acessorios": { "type": "array" },
        "compartimentos": { "type": "array" },
        "conhecimentos": { "type": "array" },
        "efeitosNegativos": { "type": "array" },
        "anotacoes": { "type": "array" },
        "escalas": { "type": "array" },
        "dadosCustomizados": { "type": "array" },
        "imagens": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nome", "userId", "updatedAt"]
    },
    "TableToken": {
      "title": "Table Token",
      "description": "A token on the VTT board",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "size": { "type": "number" },
        "imageUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["character", "creature"] },
        "hp": { "type": "number" },
        "maxHp": { "type": "number" },
        "color": { "type": "string" }
      },
      "required": ["id", "x", "y"]
    },
    "TableConfig": {
      "title": "Table Config",
      "description": "Settings for the VTT board",
      "type": "object",
      "properties": {
        "mapUrl": { "type": "string" },
        "gridSize": { "type": "number" },
        "showGrid": { "type": "boolean" },
        "masterFog": { "type": "boolean" }
      }
    },
    "BestiaryMonster": {
      "title": "Bestiary Monster",
      "description": "Template for an enemy/demon",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "maxHp": { "type": "number" },
        "esquiva": { "type": "number" },
        "acuracia": { "type": "number" },
        "deslocamento": { "type": "string" },
        "bonus": { "type": "string" },
        "ataque": {
          "type": "object",
          "properties": {
            "corte": { "type": "number" },
            "perfuracao": { "type": "number" },
            "impacto": { "type": "number" },
            "resistencia": { "type": "number" },
            "feitico": { "type": "number" },
            "elemental": { "type": "number" },
            "magiaNegra": { "type": "number" },
            "potencial": { "type": "number" }
          }
        },
        "defesa": {
          "type": "object",
          "properties": {
            "corte": { "type": "number" },
            "perfuracao": { "type": "number" },
            "impacto": { "type": "number" },
            "feitico": { "type": "number" },
            "elemental": { "type": "number" },
            "magiaNegra": { "type": "number" }
          }
        },
        "local": { "type": "string" },
        "personalidade": { "type": "string" },
        "gostaNaoGosta": { "type": "string" },
        "partesUteis": { "type": "string" },
        "informacoes": { "type": "string" },
        "habitos": { "type": "string" },
        "acoes": { "type": "array" },
        "masterId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "masterId", "ataque", "defesa"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "bestiary/{monsterId}": {
      "schema": "BestiaryMonster",
      "description": "Templates for monsters created by Game Masters"
    },
    "campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Campaigns managed by masters"
    },
    "campaigns/{campaignId}/tokens/{tokenId}": {
      "schema": "TableToken",
      "description": "Tokens active on the campaign table"
    },
    "campaigns/{campaignId}/config/main": {
      "schema": "TableConfig",
      "description": "Table configuration (map, grid, etc)"
    },
    "characters/{characterId}": {
      "schema": "Character",
      "description": "Characters created by players"
    },
    "test/connection": {
      "schema": "object",
      "description": "Connectivity test path"
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(data) { return isSignedIn() && data.userId == request.auth.uid; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }

    // Helper for validation
    function isValidCharacter(data) {
      return data.keys().hasAll(['id', 'nome', 'userId', 'createdAt', 'updatedAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.nome is string && data.nome.size() <= 200 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    // Rules for characters
    match /characters/{characterId} {
      allow get: if isSignedIn() && isOwner(existing());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                       isEmailVerified() &&
                       isValidId(characterId) && 
                       isValidCharacter(incoming());
      
      allow update: if isSignedIn() && 
                       isEmailVerified() &&
                       isOwner(existing()) &&
                       incoming().userId == existing().userId &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().updatedAt == request.time &&
                       isValidId(characterId) &&
                       // Simple update check for now, can be hardened with action-based patterns if needed
                       incoming().diff(existing()).affectedKeys().hasAny(['nome', 'etnia', 'dinheiro', 'vidaAtual', 'manaAtual', 'fome', 'sede', 'cansaco', 'defesa', 'clima', 'stats', 'statsXP', 'bonusProficiencias', 'joias', 'imagem', 'armas', 'catalisadores', 'habilidades', 'magias', 'armaduras', 'acessorios', 'compartimentos', 'conhecimentos', 'efeitosNegativos', 'anotacoes', 'escalas', 'dadosCustomizados', 'imagens', 'updatedAt']);
      
      allow delete: if isSignedIn() && isOwner(existing());
    }
  }
}
